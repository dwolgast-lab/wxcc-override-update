# Webex OAuth App credentials
# Register a Service App at https://developer.webex.com/my-apps
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback

# Session encryption secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Webex Contact Center Organization ID
# Found in Control Hub: Organization Settings
WXCC_ORG_ID=

# Formspree form ID for bug reporting
NEXT_PUBLIC_FORMSPREE_ID=
